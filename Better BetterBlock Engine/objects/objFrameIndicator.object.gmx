draw_set_alpha(1);

with (objPlayer) {
    if (fmJump1 == 23) other.j1 = "F";
    else other.j1 = string(fmJump1);
    if (fmJump2 == 19) other.j2 = "F";
    else other.j2 = string(fmJump2);
    
    other.p1 = string(fmPause1);
    other.p2 = string(fmPause2);
    
    if (fmBonk1) other.b1 = "B";
    if (fmBonk2) other.b2 = "B";
    
    other.fall = fmFall;
}

var str = "";
if (fall) {
    str = "W + " + p1 + " + " + j2 + b2 + " + " + p2;
} else {
    str = j1 + b1 + " + " + p1 + " + " + j2 + b2 + " + " + p2;
}

scrDrawTextOutline(x,y,str,c_black,c_white);

</string>
