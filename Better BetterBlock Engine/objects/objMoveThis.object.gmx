  <events>
    <event eventtype="0" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>// move them by set moveNow true
moveNow = false;

target = 0;  // id of target
pattern = 0;
/*
    0: path move
    1: direction infinite move
    2: length normal move
    3: exponential smoothing
    4: bazier move
    
    0. (pth, spd, enda, scl)
    1. (dir, spd) / (v, h)
    2. [destX, destY, time] / [(len) + (dir, spd) / (v, h)]
    3. (expt) + (dir, len) / (destX, destY)
    4. (time, pr1, pr2) + (len, dir) / (destX, destY)
*/

pth = pU1;
spd = 0;
enda = 0;
scl = 1;
dir = 0;
v = 0;
h = 0;
destX = 0;
destY = 0;
len = 32;  // px
expt = 0.05;
pr1 = 0.5;
pr2 = 1.5;
time = 100;

t = 0;

</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>/// Moving Actions

if (moveNow) {
    if (t == 0) {
        with (target) {
            xs = x;
            ys = y;
        }
    }
    
    t += 1;
    
    // move check
    if (pattern == 0) {
        // stop moving, add path
        moveNow = false;
        
        with (target) {
            path_start(other.pth, other.spd, other.enda, 0);
            path_scale = other.scl;
        }
    } else if (pattern == 1) {
        // stop moving
        moveNow = false;
        with (target) {
            if (other.spd == 0) {
                vspeed = other.v;
                hspeed = other.h;
            } else {
                direction = other.dir;
                speed = other.spd;
            }
        }
    } else if (pattern == 2) {
        if (time == 0) {
            // move without destX, destY
            with (target) {
                if (sqr(x - xs) + sqr(y - ys) &lt; sqr(other.len)) {
                    if (other.spd == 0) {
                        vspeed = other.v;
                        hspeed = other.h;
                    } else {
                        speed = other.spd;
                        direction = other.dir;
                    }
                } else {
                    speed = 0;
                    vspeed = 0;
                    hspeed = 0;
                    
                    // stop moving
                    other.moveNow = false;
                }
            }
        } else {
            // move with destX, destY, t
            var moveRate = t / time;
            
            with (target) {
                if (moveRate &lt; 1) {
                    x = lerp(xs, other.destX, moveRate);
                    y = lerp(ys, other.destY, moveRate);
                } else {
                    x = other.destX;
                    y = other.destY;
                    
                    // stop moving
                    other.moveNow = false;
                }
            }
        }
    } else if (pattern == 3) {
        if (destX == 0 &amp;&amp; destY == 0) { 
            destX = target.xs + lengthdir_x(other.len, other.dir);
            destY = target.ys + lengthdir_y(other.len, other.dir);
        }
        
        with (target) {
            if (sqr(other.destX - x) + sqr(other.destY - y) &gt; 1) {
                x = lerp(x, other.destX, other.expt);
                y = lerp(y, other.destY, other.expt);
            } else {
                x = other.destX;
                y = other.destY;
                
                // stop moving
                other.moveNow = false;
            }
        }
    } else if (pattern == 4) {
        var bazier_t = t / time;
        
        if (destX != 0 || destY != 0) {
            len = point_distance(target.xs, target.ys, destX, destY);
            dir = point_direction(target.xs, target.ys, destX, destY);
        }
        
        with (target) {
            if (bazier_t &lt;= 1) {
                scrBazierMove(bazier_t, other.dir, other.len, other.pr1, other.pr2, xs, ys);
            } else {
                // stop moving
                other.moveNow = false;
            }
        }
    }
    
}

</string>
          </argument>
        </arguments>
      </action>
    </event>
  </events>
